# =============================================================================
# Softconnect Manager — Variáveis de Ambiente
# ATENÇÃO: Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no Git.
# =============================================================================

# --- SoftConnect API (server-only — NUNCA prefixar com NEXT_PUBLIC_) ---

# URL base da SoftConnect API incluindo /api/v1
# Dev:  https://dev-api.hub.softconnect.net.br/api/v1
# Prod: https://api.hub.softconnect.net.br/api/v1
# ⚠️ PREENCHER: URL real da API fornecida pela equipe
SOFTCONNECT_API_URL=https://dev-api.hub.softconnect.net.br/api/v1

# Chave AES-256 para cifrar o JWT antes de enviar ao browser
# Gerar com: openssl rand -hex 32
# ⚠️ PREENCHER: Gere com o comando acima e guarde em local seguro
TOKEN_ENCRYPTION_KEY=<gerar_com_openssl_rand_hex_32>

# --- Configurações do App (client-safe — prefixo NEXT_PUBLIC_) ---

# Nome exibido no título do app
NEXT_PUBLIC_APP_NAME=Softconnect Manager

# URL do site institucional (exibida na tela de login)
NEXT_PUBLIC_SOFTCOM_URL=https://softcominnovation.com.br

# --- Deploy / CI-CD ---
# As variáveis abaixo são injetadas pelo Portainer/Docker Compose no ambiente de produção.
# Em desenvolvimento local, não são necessárias.
#
# PORTAINER_WEBHOOK_DEV=<url_webhook_portainer_dev>    — configurar como secret no GitHub
# PORTAINER_WEBHOOK_PROD=<url_webhook_portainer_prod>  — configurar como secret no GitHub
